# ── TrueLens Frontend env ────────────────────────────────────────────
# Axios instance in src/services/api.ts reads VITE_API_URL (include /api).
VITE_API_URL=http://localhost:8080/api

# src/services/apiService.ts reads VITE_API_BASE_URL (host only, no /api).
VITE_API_BASE_URL=http://localhost:8080

# Production example:
# VITE_API_URL=https://api.truelens.com/api
# VITE_API_BASE_URL=https://api.truelens.com
