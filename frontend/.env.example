# ============================================
# TrueLens Frontend Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local file to version control

# ─── API Configuration ──────────────────────────
# Backend API base URL
# For local development:
VITE_API_URL=http://localhost:8080/api

# Alternative API base URL (used as fallback)
VITE_API_BASE_URL=http://localhost:8080

# ─── HuggingFace API ────────────────────────────
# Optional: HuggingFace API key for client-side ML requests
# Get your key from: https://huggingface.co/settings/tokens
VITE_HF_API_KEY=your_huggingface_token_here

# ─── Application Configuration ──────────────────
# Set to true to enable debug logging
VITE_DEBUG=false

# ─── Build Configuration ────────────────────────
# These are used by Vite during build (optional)
VITE_APP_TITLE=TrueLens
