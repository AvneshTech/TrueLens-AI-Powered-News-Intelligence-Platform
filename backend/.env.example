# ============================================
# TrueLens Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# ─── Database Configuration ─────────────────────
# MySQL database URL
DB_URL=jdbc:mysql://localhost:3306/truelens

# Database username
DB_USERNAME=root

# Database password
DB_PASSWORD=your_database_password_here

# ─── API Keys ────────────────────────────────────
# NewsAPI key for fetching news articles
# Get your key from: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# HuggingFace API key for AI models
# Get your key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ─── ML Model Configuration ──────────────────────
# HuggingFace model name for predictions
HUGGINGFACE_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# ─── JWT Configuration ──────────────────────────
# Secret key for JWT token generation and validation
# Use a strong, random string (at least 32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ─── ML Service Configuration ───────────────────
# URL where the Python ML service is running
ML_SERVICE_URL=http://localhost:5000

# ─── Logging Level ──────────────────────────────
# Spring logging level (INFO, DEBUG, WARN, ERROR)
SPRING_LOGGING_LEVEL=INFO
