# ============================================
# TrueLens Backend Environment Variables
# ============================================

# ─────────────────────────────────────────────
# MongoDB Configuration
# ─────────────────────────────────────────────

# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/truelens

# MongoDB Atlas (Production Example)
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/truelens?retryWrites=true&w=majority

# ─────────────────────────────────────────────
# JWT Configuration
# ─────────────────────────────────────────────

JWT_SECRET=replace_with_a_secure_32_plus_character_secret_key

# JWT Expiration (milliseconds)
JWT_EXPIRATION=86400000

# ─────────────────────────────────────────────
# News API Configuration
# ─────────────────────────────────────────────

NEWS_API_KEY=your_newsapi_key_here

# ─────────────────────────────────────────────
# Hugging Face Configuration
# ─────────────────────────────────────────────

HUGGINGFACE_API_KEY=your_huggingface_api_key_here

HUGGINGFACE_MODEL=distilbert-base-uncased-finetuned-sst-2-english

HUGGINGFACE_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment

# ─────────────────────────────────────────────
# ML Service Configuration
# ─────────────────────────────────────────────

ML_SERVICE_URL=http://localhost:5000

# ─────────────────────────────────────────────
# Email Verification (Resend)
# ─────────────────────────────────────────────

RESEND_API_KEY=your_resend_api_key_here

MAIL_FROM=TrueLens <onboarding@resend.dev>

APP_FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────

APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# Multiple Origins Example:
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://truelens.vercel.app

# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────

PORT=8080

SPRING_LOGGING_LEVEL=INFO